# Normalize line endings
* text=auto

# Force LF for markdown and source files
*.md text eol=lf
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.py text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files - no conversion
*.exe binary
*.dll binary
*.sys binary
*.obj binary
*.pyc binary
*.pyd binary
