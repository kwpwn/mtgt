<?xml version="1.0" encoding="utf-8"?>
<!--
  Visual Studio project for wfp_callout.sys
  Requires: WDK 10 + Visual Studio 2019/2022
  Build: msbuild wfp_callout.vcxproj /p:Configuration=Release /p:Platform=x64
  Then sign with: signtool sign /fd sha256 /v wfp_callout.sys
  For test: bcdedit /set testsigning on && restart
-->
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <ConfigurationType>Driver</ConfigurationType>
    <DriverType>WDM</DriverType>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <Platform>x64</Platform>
    <ProjectGuid>{11111111-1111-1111-1111-111111111111}</ProjectGuid>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup>
    <ConfigurationType>Driver</ConfigurationType>
    <TargetName>wfp_callout</TargetName>
    <TargetExt>.sys</TargetExt>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
  <ImportGroup Label="Shared" />

  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>_X86_=1;i386=1;STD_CALL;WINVER=0x0A00;_WIN64;_AMD64_;AMD64;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(DDK_INC_PATH);%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>false</TreatWarningAsError>
    </ClCompile>
    <Link>
      <AdditionalDependencies>fwpkclnt.lib;wdmsec.lib;ndis.lib;%(AdditionalDependencies)</AdditionalDependencies>
      <EntryPointSymbol>DriverEntry</EntryPointSymbol>
    </Link>
  </ItemDefinitionGroup>

  <ItemGroup>
    <ClCompile Include="wfp_callout.c" />
  </ItemGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />
</Project>
